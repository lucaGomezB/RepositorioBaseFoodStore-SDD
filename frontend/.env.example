# =============================================
# FOOD STORE - Frontend Environment Variables
# =============================================
# Variables con prefijo VITE_ son expuestas al bundle de producción
# Copiar este archivo a .env.local y completar valores

# ---------------------------------------------
# API BACKEND
# ---------------------------------------------
# URL base del backend (incluye prefijo /api/v1)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------------------------------------------
# MERCADOPAGO
# ---------------------------------------------
# Public Key de MercadoPago (para SDK JS en el frontend)
# Usar TEST-... para desarrollo, APP-... para producción
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-your-mercadopago-public-key

# ---------------------------------------------
# ENVIRONMENT
# ---------------------------------------------
VITE_ENV=development
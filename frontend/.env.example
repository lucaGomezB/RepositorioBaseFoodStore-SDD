# =============================================
# FOOD STORE - Frontend Environment Variables
# =============================================
# Variables con prefijo VITE_ son expuestas al bundle de producción
# Copiar este archivo a .env.local y completar valores

# ---------------------------------------------
# API BACKEND
# ---------------------------------------------
# URL base del backend. Por defecto usa /api/v1 (proxy de Vite en desarrollo).
# Solo descomentar si NO usas el proxy de Vite (ej: produccion con dominio separado).
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------------------------------------------
# MERCADOPAGO
# ---------------------------------------------
# Public Key de MercadoPago (para SDK JS en el frontend)
# Usar TEST-... para desarrollo, APP-... para producción
# La usa el componente CardPaymentForm
VITE_MP_PUBLIC_KEY=TEST-your-mercadopago-public-key

# ---------------------------------------------
# LOGIN (Conceptual / Demo)
# ---------------------------------------------
# Credenciales para el login conceptual (LoginConceptual.tsx)
# Solo para desarrollo/demo. NO usar en producción.
VITE_LOGIN_USER=admin
VITE_LOGIN_PASS=admin123

# ---------------------------------------------
# ENVIRONMENT
# ---------------------------------------------
# Valores: development, production
VITE_ENV=development
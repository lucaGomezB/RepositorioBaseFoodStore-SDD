# =============================================
# FOOD STORE - Backend Environment Variables
# =============================================
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio

# ---------------------------------------------
# DATABASE
# ---------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/foodstore_db

# ---------------------------------------------
# SECURITY - JWT Configuration
# ---------------------------------------------
# IMPORTANTE: En producción, cambiar a una clave segura de mínimo 32 caracteres
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------
# CORS - Cross-Origin Resource Sharing
# ---------------------------------------------
# Orígenes permitidos (separados por coma, sin espacios)
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.com
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------
# MERCADOPAGO - Payment Gateway
# ---------------------------------------------
# Obtener credenciales en: https://www.mercadopago.com.ar/developers/es
# TEST tokens para desarrollo, PROD tokens para producción
MERCADOPAGO_ACCESS_TOKEN=TEST-your-mercadopago-access-token
MERCADOPAGO_PUBLIC_KEY=TEST-your-mercadopago-public-key
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# ---------------------------------------------
# LOGGING
# ---------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------
# ENVIRONMENT
# ---------------------------------------------
ENVIRONMENT=development